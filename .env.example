# URL canonique du site (SEO, Open Graph, sitemap). Exemple prod : https://www.votredomaine.tn
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin : rôle `admin` dans Supabase (app_metadata / user_metadata), ou liste d’emails (CSV)
ADMIN_EMAILS=

# Exemple : dlgmngeyj (Djerba First Car)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=djerbafirstcar_cars

# WhatsApp : numéro avec indicatif, ex. +21612345678
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Affichage navbar / footer (peut inclure espaces)
NEXT_PUBLIC_PHONE_DISPLAY=+216 XX XXX XXX

# Emails (Resend) — notifications nouveaux leads / messages contact
RESEND_API_KEY=
# Adresse d’expédition vérifiée chez Resend (ex. onboarding@resend.dev en test)
RESEND_FROM_EMAIL=
# Destinataire des alertes (sinon : premier email de ADMIN_EMAILS)
ADMIN_NOTIFY_EMAIL=

# Rate limiting optionnel (Upstash Redis) — sinon : honeypot uniquement
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
