# URL canonique du site (SEO, Open Graph, sitemap). Exemple prod : https://www.votredomaine.tn
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin : rôle `admin` dans Supabase (app_metadata / user_metadata), ou liste d’emails (CSV)
ADMIN_EMAILS=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=djerbafirstcar_cars

# WhatsApp : numéro avec indicatif, ex. +21612345678
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Affichage navbar / footer (peut inclure espaces)
NEXT_PUBLIC_PHONE_DISPLAY=+216 XX XXX XXX

RESEND_API_KEY=
